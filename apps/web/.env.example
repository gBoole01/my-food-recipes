## API ##
# Base URL of the NestJS backend (used by both client components and server-side fetches)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

## MOCKS ##
# Set to "false" to disable mocks and use the real backend
NEXT_PUBLIC_USE_MOCKS=true

## ADMIN ##
# Must match ADMIN_API_KEY in apps/api/.env
ADMIN_API_KEY=
